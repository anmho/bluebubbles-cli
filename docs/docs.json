{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bluebubbles-cli",
  "colors": {
    "primary": "#1d4ed8",
    "light": "#2563eb",
    "dark": "#1e40af"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "index",
              "quickstart",
              "cli-reference",
              "webhooks",
              "local-server",
              "doctor",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "v1",
            "openapi": "openapi.yaml"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "BlueBubbles Docs",
          "href": "https://docs.bluebubbles.app",
          "icon": "square-code"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Jish2/bluebubbles-sdk"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Jish2/bluebubbles-sdk",
      "website": "https://docs.bluebubbles.app"
    }
  }
}
